# Database Configuration
DATABASE_URL=postgresql://agronomist:agronomist_dev@localhost:5432/agronomist
DB_USER=agronomist
DB_PASSWORD=agronomist_dev
DB_NAME=agronomist
DATABASE_SSL_MODE=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# App Configuration
APP_NAME=AI Agronomist MVP
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
LOG_LEVEL=INFO
LOG_FORMAT=plain
LOG_ACCESS=true

# Auth Configuration
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# Upload / Storage Configuration
STORAGE_BACKEND=local
UPLOAD_DIR=uploads
KNOWLEDGE_STORAGE_DIR=knowledge_uploads
MAX_IMAGE_UPLOAD_SIZE_MB=10

# Vision AI Configuration
GEMINI_API_KEY=
VISION_PROVIDER=gemini
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
GEMINI_REQUEST_TIMEOUT_SECONDS=20

# Knowledge / RAG Configuration
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_CHUNK_OVERLAP=180
KNOWLEDGE_SEARCH_CACHE_TTL_SECONDS=300

# Agricultural Intelligence Configuration
INTELLIGENCE_SOURCE_CONFIG_PATH=config/intelligence_sources.example.json
INTELLIGENCE_SYNC_ENABLED=false
INTELLIGENCE_SYNC_INTERVAL_SECONDS=86400
INTELLIGENCE_REQUEST_TIMEOUT_SECONDS=15
INTELLIGENCE_REQUEST_RETRIES=3
NEWS_CACHE_TTL_SECONDS=300
FARM_WEATHER_CACHE_TTL_SECONDS=900
WEATHER_CACHE_TTL_SECONDS=900
WEATHER_STALE_TTL_SECONDS=3600
WEATHER_MAX_RETRIES=1
WEATHER_PROVIDER_COOLDOWN_SECONDS=300
FARM_MARKET_CACHE_TTL_SECONDS=900
FARM_ADVISORY_CACHE_TTL_SECONDS=1800
FARM_SOIL_CACHE_TTL_SECONDS=43200
FARM_RISK_CACHE_TTL_SECONDS=1800
FARM_NEWS_CACHE_TTL_SECONDS=900
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPENWEATHER_GEOCODING_URL=https://api.openweathermap.org/geo/1.0/direct
OPENWEATHER_FORECAST_URL=https://api.openweathermap.org/data/2.5/forecast
OPENWEATHER_API_KEY=
WEATHERAPI_BASE_URL=https://api.weatherapi.com/v1
WEATHERAPI_API_KEY=
GEOCODING_PROVIDER=nominatim
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_USER_AGENT=ai-agronomist/0.1 (configure NOMINATIM_USER_AGENT)
GEOCODING_CACHE_TTL_SECONDS=86400
GEOCODING_MIN_INTERVAL_MS=1100

# Server Configuration
HOST=0.0.0.0
PORT=8000
STARTUP_VALIDATE_DATABASE=true
STARTUP_VALIDATE_PGVECTOR=true
STARTUP_VALIDATE_STORAGE=true
